<Page x:Class="WpfPM02AutoShow.Pages.AddPageTreaties"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfPM02AutoShow.Pages"
        mc:Ignorable="d"
      d:DesignHeight="450" d:DesignWidth="800"
        Title="AddPageTreaties">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>

        </Grid.RowDefinitions>
        <TextBlock Text="Код договора" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
        <TextBlock Text="Дата" Foreground="White" Grid.Row="1"/>
        <TextBlock Text="Сотрудник" Foreground="White" Grid.Row="2"/>
        <TextBlock Text="Автомобиль" Foreground="White" Grid.Row="3"/>
        <TextBlock Text="Цена" Foreground="White" Grid.Row="4"/>
        <TextBlock Text="Способ оплаты" Foreground="White" Grid.Row="5"/>
        <TextBlock Text="Статус выполнения" Foreground="White" Grid.Row="6"/>
        <TextBox Text="{Binding id_Договора}" Grid.Column="1" HorizontalAlignment="Left" Margin="36,0,0,0" TextWrapping="Wrap" Width="226" Height="24"/>
        <TextBox Text="{Binding Дата}" Grid.Column="1" HorizontalAlignment="Left" Margin="36,0,0,0" TextWrapping="Wrap" Width="226" Height="24" Grid.Row="1"/>
        <TextBox Text="{Binding Сотрудники.ФИО}" Grid.Column="1" HorizontalAlignment="Left" Margin="36,0,0,0" TextWrapping="Wrap" Width="226" Height="24" Grid.Row="2"/>
        <TextBox Text="{Binding Автомобили.Марка}" Grid.Column="1" HorizontalAlignment="Left" Margin="36,0,0,0" TextWrapping="Wrap" Width="226" Height="24" Grid.Row="3"/>
        <TextBox Text="{Binding Автомобили.Цена}" Grid.Column="1" HorizontalAlignment="Left" Margin="36,0,0,0" TextWrapping="Wrap" Width="226" Height="24" Grid.Row="4"/>
        <TextBox Text="{Binding СпособыОплаты.НазваниеСпособаОплаты}" Grid.Column="1" HorizontalAlignment="Left" Margin="36,0,0,0" TextWrapping="Wrap" Width="226" Height="24" Grid.Row="5"/>
        <TextBox Text="{Binding СтатусВыполнения}" Grid.Column="1" HorizontalAlignment="Left" Margin="36,0,0,0" TextWrapping="Wrap" Width="226" Height="24" Grid.Row="6"/>
        <Button Content="Сохранить" Grid.Row="7" x:Name="BtnSave" Click="BtnSave_Click" Margin="0,7,230,17" Background="{x:Null}" BorderBrush="Black" Foreground="Black" Grid.Column="1"/>
    </Grid>
</Page>
