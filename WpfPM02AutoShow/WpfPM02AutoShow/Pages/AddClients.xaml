<Page x:Class="WpfPM02AutoShow.Pages.AddClients"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfPM02AutoShow.Pages"
        mc:Ignorable="d"
      d:DesignHeight="450" d:DesignWidth="800"
        Title="AddClients">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <TextBlock Text="Код клиента" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
        <TextBlock Text="ФИО" Foreground="White" Grid.Row="1"/>
        <TextBlock Text="Телефон" Foreground="White" Grid.Row="2"/>
        <TextBlock Text="Электронная почта" Foreground="White" Grid.Row="3"/>
        <TextBox Text="{Binding id_клиента}" Grid.Column="1" HorizontalAlignment="Left" Margin="36,0,0,0" TextWrapping="Wrap" Width="226" Height="24"/>
        <TextBox Text="{Binding ФИО}" Grid.Column="1" HorizontalAlignment="Left" Margin="36,0,0,0" TextWrapping="Wrap" Width="226" Height="24" Grid.Row="1"/>
        <TextBox Text="{Binding Телефон}" Grid.Column="1" HorizontalAlignment="Left" Margin="36,0,0,0" TextWrapping="Wrap" Width="226" Height="24" Grid.Row="2"/>
        <TextBox Text="{Binding Email}" Grid.Column="1" HorizontalAlignment="Left" Margin="36,0,0,0" TextWrapping="Wrap" Width="226" Height="24" Grid.Row="3"/>
        <Button Content="Сохранить" Grid.Row="4" x:Name="BtnSave" Click="BtnSave_Click" Margin="164,18,265,28" Grid.ColumnSpan="2" Background="{x:Null}" BorderBrush="Black" Foreground="Black"/>
    </Grid>
</Page>
