<Page x:Class="WpfPM02AutoShow.Pages.AddEmployees"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfPM02AutoShow.Pages"
        mc:Ignorable="d"
      d:DesignHeight="450" d:DesignWidth="800"
        Title="AddEmployees">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <TextBlock Text="Код сотрудника" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
        <TextBlock Text="ФИО" Foreground="White" Grid.Row="1"/>
        <TextBlock Text="Должность" Foreground="White" Grid.Row="2"/>
        <TextBlock Text="Дата рождения" Foreground="White" Grid.Row="3"/>
        <TextBlock Text="Дата приёма на работу" Foreground="White" Grid.Row="4"/>
        <TextBox Text="{Binding id_Сотрудника}" Grid.Column="1" HorizontalAlignment="Left" Margin="36,0,0,0" TextWrapping="Wrap" Width="226" Height="24"/>
        <TextBox Text="{Binding ФИО}" Grid.Column="1" HorizontalAlignment="Left" Margin="36,0,0,0" TextWrapping="Wrap" Width="226" Height="24" Grid.Row="1"/>
        <TextBox Text="{Binding Должности.НаименованиеДолжности}" Grid.Column="1" HorizontalAlignment="Left" Margin="36,0,0,0" TextWrapping="Wrap" Width="226" Height="24" Grid.Row="2"/>
        <TextBox Text="{Binding ДатаРождения}" Grid.Column="1" HorizontalAlignment="Left" Margin="36,0,0,0" TextWrapping="Wrap" Width="226" Height="24" Grid.Row="3"/>
        <TextBox Text="{Binding ДатаПриёмаНаРаботу}" Grid.Column="1" HorizontalAlignment="Left" Margin="36,0,0,0" TextWrapping="Wrap" Width="226" Height="24" Grid.Row="4"/>
        <TextBlock Text="Зарплата" Foreground="White" Grid.Row="5"/>
        <TextBlock Text="Телефон" Foreground="White" Grid.Row="6"/>
        <TextBlock Text="Email" Foreground="White" Grid.Row="7"/>
        <TextBlock Text="Логин" Foreground="White" Grid.Row="8"/>
        <TextBlock Text="Пароль" Foreground="White" Grid.Row="9"/>
        <TextBox Text="{Binding Зарплата}" Grid.Column="1" HorizontalAlignment="Left" Margin="36,0,0,0" TextWrapping="Wrap" Width="226" Height="24" Grid.Row="5"/>
        <TextBox Text="{Binding Телефон}" Grid.Column="1" HorizontalAlignment="Left" Margin="36,0,0,0" TextWrapping="Wrap" Width="226" Height="24" Grid.Row="6"/>
        <TextBox Text="{Binding Email}" Grid.Column="1" HorizontalAlignment="Left" Margin="36,0,0,0" TextWrapping="Wrap" Width="226" Height="24" Grid.Row="7"/>
        <TextBox Text="{Binding Логин}" Grid.Column="1" HorizontalAlignment="Left" Margin="36,0,0,0" TextWrapping="Wrap" Width="226" Height="24" Grid.Row="8"/>
        <TextBox Text="{Binding Пароль}" Grid.Column="1" HorizontalAlignment="Left" Margin="36,0,0,0" TextWrapping="Wrap" Width="226" Height="24" Grid.Row="9"/>
        <Button Content="Сохранить" Grid.Row="10" x:Name="BtnSave" Click="BtnSave_Click" Margin="176,10,253,26" Grid.RowSpan="2" Grid.ColumnSpan="2" Background="{x:Null}" BorderBrush="Black" Foreground="Black"/>

    </Grid>
</Page>
