<Page x:Class="WpfPM02AutoShow.Pages.Cars"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfPM02AutoShow.Pages"
        mc:Ignorable="d"
        d:DesignHeight="450" d:DesignWidth="800"
        Title="Cars" IsVisibleChanged="Page_IsVisibleChanged">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="377"/>
            <RowDefinition Height="50"/>
        </Grid.RowDefinitions>
        <DataGrid x:Name="DGrid" AutoGenerateColumns="False" IsReadOnly="True" Margin="0,0,0,100">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Код автомобиля" Binding="{Binding id_Автомобиля}" Width="*"></DataGridTextColumn>
                <DataGridTextColumn Header="Марка" Binding="{Binding Марка}" Width="*"></DataGridTextColumn>
                <DataGridTextColumn Header="Поставщик" Binding="{Binding Поставщики.НаименованиеПоставщика}" Width="*"></DataGridTextColumn>
                <DataGridTextColumn Header="Цвет" Binding="{Binding Цвет}" Width="*"></DataGridTextColumn>
                <DataGridTextColumn Header="Количество мест" Binding="{Binding КоличествоМест}" Width="*"></DataGridTextColumn>
                <DataGridTextColumn Header="Максимальная скорость" Binding="{Binding Максимальная_скорость}" Width="*"></DataGridTextColumn>
                <DataGridTextColumn Header="Тип двигателя" Binding="{Binding Тип_двигателя}" Width="*"></DataGridTextColumn>
                <DataGridTextColumn Header="Рабочий объём двигателя" Binding="{Binding Рабочий_объем_двигателя}" Width="*"></DataGridTextColumn>
                <DataGridTextColumn Header="Система подачи топлива" Binding="{Binding Система_подачи_топлива}" Width="*"></DataGridTextColumn>
                <DataGridTextColumn Header="Расход топлива" Binding="{Binding Расход_топлива}" Width="*"></DataGridTextColumn>

                <DataGridTemplateColumn Width="auto">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Content="Редактировать" Name="BtnEdit" Click="BtnEdit_Click" Foreground="Black" ></Button>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
        <Button Content="Добавить" HorizontalAlignment="Left" x:Name="BtnAdd" Click="BtnAdd_Click" FontFamily="Times New Roman" FontSize="14" Height="28" Width="170" Background="{x:Null}" BorderBrush="Black" Foreground="Black" Margin="0,290,0,59"/>
        <Button Content="Удалить" HorizontalAlignment="Right" Name="BtnDelete" Click="BtnDelete_Click" FontFamily="Times New Roman" FontSize="14" Height="28" Width="170" Background="{x:Null}" BorderBrush="Black" Foreground="Black" Margin="0,290,10,59"/>
    </Grid>
</Page>
