<Page x:Class="WpfPM02AutoShow.Pages.PageTreaties"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfPM02AutoShow.Pages"
        mc:Ignorable="d"
       d:DesignHeight="450" d:DesignWidth="800"
        Title="PageTreaties" IsVisibleChanged="Page_IsVisibleChanged">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="377"/>
            <RowDefinition Height="50"/>
        </Grid.RowDefinitions>
        <DataGrid x:Name="DGrid" AutoGenerateColumns="False" IsReadOnly="True" Margin="0,0,0,119">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Код договора" Binding="{Binding id_Договора}" Width="*"></DataGridTextColumn>
                <DataGridTextColumn Header="Дата" Binding="{Binding Дата}" Width="*"></DataGridTextColumn>
                <DataGridTextColumn Header="Сотрудник" Binding="{Binding Сотрудники.ФИО}" Width="*"></DataGridTextColumn>
                <DataGridTextColumn Header="Автомобиль" Binding="{Binding Автомобили.Марка}" Width="*"></DataGridTextColumn>
                <DataGridTextColumn Header="Способ оплаты" Binding="{Binding СпособыОплаты.НазваниеСпособаОплаты}" Width="*"></DataGridTextColumn>
                <DataGridTextColumn Header="Статус выполнения" Binding="{Binding СтатусВыполнения}" Width="*"></DataGridTextColumn>

                <DataGridTemplateColumn Width="auto">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Content="Редактировать" Name="BtnEdit" Click="BtnEdit_Click" Foreground="Black" ></Button>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
        <Button Content="Добавить" HorizontalAlignment="Left" x:Name="BtnAdd" Click="BtnAdd_Click" FontFamily="Times New Roman" FontSize="14" Width="196" Background="{x:Null}" BorderBrush="Black" Foreground="Black" Margin="0,263,0,88"/>
        <Button Content="Удалить" HorizontalAlignment="Right" x:Name="BtnDelete" Click="BtnDelete_Click" FontFamily="Times New Roman" FontSize="14" Width="221" Background="{x:Null}" BorderBrush="#FF0050FF" Foreground="#FF0050FF" Margin="0,263,0,88"/>
        <Button x:Name="BtnXpert" Content="Button" HorizontalAlignment="Left" Margin="41,319,0,0" VerticalAlignment="Top" Click="BtnXpert_Click" BorderBrush="Black"/>
    </Grid>
</Page>
