<Window x:Class="WpfPM02AutoShow.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfPM02AutoShow"
        mc:Ignorable="d"
        AllowsTransparency="True"
        Title="MainWindow" Height="450" WindowStyle="None" WindowStartupLocation="CenterScreen" MouseLeftButtonDown="MoveForm" Width="396">
    <Window.Clip>
        <RectangleGeometry Rect="0,0,396,450" RadiusX="30" RadiusY="30"/>
    </Window.Clip>
    <Grid>
        <Grid.Background>
            <LinearGradientBrush EndPoint="0.5,1" StartPoint="-0.3,0.5">
                <GradientStop Color="White"/>
                <GradientStop Color="#996699" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>
        <TextBox x:Name="passwordTextBox" HorizontalAlignment="Left" Margin="103,232,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="195" Height="24" Background="{x:Null}" BorderBrush="#FF08FF00" Foreground="White"/>

        <Label Content="Логин" HorizontalAlignment="Left" Margin="45,176,0,0" VerticalAlignment="Top" Height="28" Width="51" FontFamily="Times New Roman" FontSize="14" FontWeight="Bold" Foreground="Black"/>
        <Label Content="Пароль" HorizontalAlignment="Left" Margin="42,229,0,0" VerticalAlignment="Top" Height="27" FontFamily="Times New Roman" FontSize="14" FontWeight="Bold" Foreground="Black"/>
        <TextBox x:Name="loginTextBox" HorizontalAlignment="Left" Margin="103,180,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="195" Height="24" FontFamily="Times New Roman" FontSize="14" Background="{x:Null}" BorderBrush="Black" Foreground="Black" SelectionBrush="Black"/>
        <PasswordBox x:Name="passwordBox" HorizontalAlignment="Left" VerticalAlignment="Top" Width="195" Margin="103,232,0,0" Height="24" FontFamily="Times New Roman" FontSize="14" Background="{x:Null}" BorderBrush="Black" Foreground="#FF080C16" SelectionBrush="Black"/>
        <Button x:Name="loginBtn" Content="Войти" HorizontalAlignment="Center" Margin="0,291,0,0" VerticalAlignment="Top" FontFamily="Times New Roman" FontSize="14" Click="Button_Click" Width="88" Height="28" Background="{x:Null}" BorderBrush="Black" Foreground="Black" Grid.ColumnSpan="2"/>
        <CheckBox x:Name="CheckBoxPwd" Content="Показать/Скрыть" HorizontalAlignment="Left" Margin="198,261,0,0" VerticalAlignment="Top" Click="CheckBoxPwd_Click1" Foreground="Black"/>
        <Image HorizontalAlignment="Center" Height="104" Margin="0,60,0,0" VerticalAlignment="Top" Width="130" Source="/image/png-transparent-car-dealership-alsa-enterprises-motors-used-car-vehicle-car-blue-text-hand.png" OpacityMask="#FF08FF00"/>
        <Label Content="X" HorizontalAlignment="Left" MouseDoubleClick="ExitForm" Margin="352,0,0,0" VerticalAlignment="Top" FontSize="36" FontWeight="Bold" Foreground="Black"/>
        

    </Grid>
</Window>
